# ============================================================
# BuildPOS — Environment Variables (namuna)
# Haqiqiy .env faylini shu asosida yarating
# .env fayli hech qachon Git ga yuklanmaydi!
# ============================================================

# Database
SPRING_DATASOURCE_URL=jdbc:postgresql://localhost:5432/buildpos_db
SPRING_DATASOURCE_USERNAME=buildpos_user
SPRING_DATASOURCE_PASSWORD=yourStrongPassword123!

# JWT (kamida 32 belgi, tasodifiy string)
JWT_SECRET=your-very-long-random-secret-key-at-least-32-characters-here

# Uploads papkasi (Docker da)
APP_UPLOAD_DIR=/app/uploads
