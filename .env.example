# ================================================
# BuildPOS — Environment Variables
# ================================================
# Bu faylni ko'chirib .env nomi bilan saqlang:
#   cp .env.example .env
# Keyin qiymatlarni to'ldiring.
# DIQQAT: .env faylini hech qachon GitHub ga yuklamang!
# ================================================

# PostgreSQL
POSTGRES_DB=buildpos_db
POSTGRES_USER=buildpos_user
POSTGRES_PASSWORD=YOUR_STRONG_PASSWORD_HERE

# JWT Secret (kamida 64 ta tasodifiy belgi)
# Yaratish: openssl rand -hex 64
JWT_SECRET=YOUR_JWT_SECRET_HERE

# Domen
APP_DOMAIN=primestroy.uz
